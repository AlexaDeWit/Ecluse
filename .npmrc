# Écluse is a supply-chain-security proxy, so our own tooling and CI must never execute
# upstream npm lifecycle scripts (preinstall / install / postinstall / prepare / …): they
# are an arbitrary-code-execution surface we refuse to expose in our own build. Disabling
# them here covers every in-repo npm invocation and Renovate, which honours this file.
#
# Test harnesses that drive npm in throwaway projects OUTSIDE this tree cannot rely on this
# file — npm's config resolution will not find it from there — so they additionally set
# npm_config_ignore_scripts in the npm child's environment (see test/e2e/Ecluse/E2E/Harness.hs).
ignore-scripts=true
