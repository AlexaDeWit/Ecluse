{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  // One bot for the ecosystems this repo automates: Nix flake inputs, GitHub
  // Actions, and (the reason we left Dependabot) Haskell/Hackage cabal
  // dependencies, which Dependabot has no manager for. Runs as the hosted Mend
  // "Renovate Community Cloud" app (free for public repos). Deliberately out of
  // scope: the version pins inside flake.nix (callHackageDirect, fetchFromGitHub,
  // fetchurl); each is a hash-pinned, hand-audited choice a bot cannot bump
  // without also recomputing the hash, and the Haskell ones still reach OSV
  // alerting through the freeze arm below.
  extends: [
    "config:recommended",
    // Keep every GitHub Action pinned to a full-length commit SHA with the
    // version in a trailing comment — the repo's supply-chain rule (AGENTS.md
    // → "CI & Security"). Renovate updates both the digest and the comment and
    // never unpins.
    "helpers:pinGitHubActionDigests",
  ],

  // Mirror the deliberate weekly cadence the old Dependabot config used. UTC —
  // a bot needs no local timezone.
  schedule: ["before 9am on monday"],

  // Conventional Commits, matching the repo's history. Default scope is "deps";
  // the per-manager commit *type* is set in packageRules below to preserve the
  // old prefixes (build → flake/cabal, ci → actions).
  semanticCommits: "enabled",

  labels: ["dependencies"],

  // The nix manager is beta and disabled by default; without this block the
  // flake.lock maintenance below never runs at all (which is exactly what
  // happened from the Renovate migration until this block was added; see
  // docs/architecture/release-supply-chain.md).
  nix: {
    enabled: true,
  },

  // Frozen reference data, not dependencies. bench/corpus pins live in a plain
  // pins.json (deliberately not package.json-shaped, so no manager detects it)
  // and the captures are re-generated by `task gen-bench-corpus`, never
  // auto-bumped; test/oracles pins the node-semver differential-test oracle,
  // refreshed by hand so an auto-bump can never silently change what the suite
  // tests against. (The defaults from config:recommended are restated so this
  // override does not drop them.) See docs/architecture/performance.md and
  // docs/testing.md.
  ignorePaths: [
    "**/node_modules/**",
    "**/bower_components/**",
    "bench/corpus/**",
    "test/oracles/**",
  ],

  // OSV-based vulnerability alerting, kept as belt-and-suspenders ONLY. The
  // option is experimental in Renovate and empirically raised nothing on the
  // hosted Mend app despite qualifying HSEC advisories with released fixes
  // (verified 2026-07-18; see release-supply-chain.md), so the Haskell
  // detection arm of record is the scheduled OSV.dev scan in security.yml
  // (scripts/osv-freeze-scan.sh), not this flag. It stays enabled because it
  // costs nothing and may begin working; if it ever raises a fix-PR that edits
  // one line of the generated freeze, that PR fails checks.freeze-sync by
  // design, and the real fix is a flake-side bump plus `task freeze`.
  osvVulnerabilityAlerts: true,

  // Refresh flake.lock weekly. The inputs track *branches* (nixos-26.05), which
  // carry no version for Renovate to bump; a lock refresh is how the whole
  // closure moves forward, C libraries and Haskell package set alike. This is
  // the single freshness lever now that the freeze is derived from the set. If
  // a refresh moves Haskell versions, checks.freeze-sync reds the PR and one
  // `task freeze` commit completes it (docs/getting-started.md → "Dependency locking").
  lockFileMaintenance: {
    enabled: true,
    schedule: ["before 9am on monday"],
  },

  // Renovate has no manager for `cabal.project.freeze` (its sole Haskell
  // manager, `haskell-cabal`, matches only `*.cabal` files and parses only the
  // explicit `>= && <` bound form: today the two tls bounds and
  // optparse-applicative, missing every caret-bounded declaration and the whole
  // transitive tree). The freeze is machine-generated (flake.nix `cabal-freeze`,
  // copied by `task freeze`), so its format is dead-uniform and this one-line
  // regex extracts the full resolved closure at exact versions, feeding the
  // Dependency Dashboard inventory and the (uncredited) OSV alerting above.
  // Caveat: the amazonka entries name the Hackage 2.0 release, while the real
  // source is the git rev pinned in flake.nix and cabal.project.
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)cabal\\.project\\.freeze$/"],
      matchStrings: [
        "any\\.(?<depName>[a-zA-Z0-9][a-zA-Z0-9-]*) ==(?<currentValue>[0-9][0-9.]*)",
      ],
      datasourceTemplate: "hackage",
      versioningTemplate: "pvp",
    },
  ],

  // GHC's *virtual* packages are in the freeze but not published on Hackage, so
  // the lookup fails ("failed to look up hackage package rts"). They are
  // compiler internals, not dependencies. Everything else in the freeze,
  // GHC-bundled or not, stays visible: with the freeze equal to the shipped
  // closure, an HSEC advisory on any of it is worth an alert.
  ignoreDeps: ["rts", "system-cxx-std-lib"],

  packageRules: [
    // Flake inputs + the flake.lock refresh → build(deps).
    {
      matchManagers: ["nix"],
      semanticCommitType: "build",
    },

    // Haskell library bounds in ecluse.cabal → build(deps). "widen" only raises
    // UPPER bounds, so a new Hackage release is *allowed* without forcing a
    // lower bound the nixpkgs set (the version authority) cannot satisfy.
    {
      matchManagers: ["haskell-cabal"],
      semanticCommitType: "build",
      rangeStrategy: "widen",
    },

    // The freeze is a *generated* projection of the Nix package set; hand-edits
    // to single lines fight the generator and fail checks.freeze-sync. So
    // freeze deps surface on the Dependency Dashboard for visibility but never
    // as routine update PRs; HSEC fix-PRs (osvVulnerabilityAlerts above) are
    // still raised, as alarms whose real fix is flake-side.
    {
      matchFileNames: ["cabal.project.freeze"],
      semanticCommitType: "build",
      dependencyDashboardApproval: true,
    },

    // GitHub Actions → ci(deps).
    {
      matchManagers: ["github-actions"],
      semanticCommitType: "ci",
    },
  ],
}
