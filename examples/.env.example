# Copy to .env and fill in. Compose reads this beside docker-compose.yml.

# Pin by digest: the registry publishes immutable version tags and no `latest`.
ECLUSE_IMAGE=ghcr.io/alexadewit/ecluse@sha256:REPLACE_WITH_RELEASE_DIGEST

# The proxy's own externally-reachable base URL: served tarball URLs are
# rewritten against it, and it is required as soon as any mount is active.
ECLUSE_SERVER__PUBLIC_URL=http://127.0.0.1:4873

# Mirror profile only: the vetted private registry and the mirror-write target
# (declaring the target is what makes the mount mirrored; the write token goes
# into ./secrets/mirror_target_token, never in here).
ECLUSE_MOUNTS__NPM__PRIVATE_UPSTREAM=https://your-registry.example.com/npm/
ECLUSE_MOUNTS__NPM__MIRROR_TARGET=https://your-registry.example.com/npm/
