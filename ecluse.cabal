executable ecluse
  import:         shared
  -- The threaded runtime is required: with telemetry enabled the OpenTelemetry SDK
  -- runs a batch span processor on a background thread, which aborts under the
  -- non-threaded RTS. -N lets the server and worker use every core.
  --
  -- -A64m -n4m tune the GC for the serve path's allocation profile: assembling and
  -- re-serialising a many-version packument allocates tens of MB per request, and
  -- the default 4 MB allocation area makes the process collect hundreds of times a
  -- second under load (GC was ~half the wall time in the load benchmarks). A 64 MB
  -- per-capability allocation area divided into 4 MB chunks (so capabilities share
  -- it instead of stranding idle nurseries) cuts the collection count by an order
  -- of magnitude. Operators can override at run time, e.g.
  -- `ecluse +RTS -A16m -RTS`, since -rtsopts is set; see USAGE.md.
  ghc-options:    -threaded -rtsopts "-with-rtsopts=-N -A64m -n4m"
  main-is:        Main.hs
  hs-source-dirs: app
  build-depends:  ecluse

-- The capability-manifest assembly: the pure (ManifestSource -> OpenApi) builder
-- and the owned schemas. An INTERNAL sublibrary (the ecluse-test-support pattern)
-- so the heavy OpenAPI dependency tree (openapi3 + autodocodec + lens/optics/…)
-- stays OUT of the shipped `library ecluse` / `executable ecluse` closure: it is
-- depended on only by the openapi-gen generator and the ecluse-unit test suite,
-- never by the app library. It links ecluse-core (the Route enumeration and the
-- served types), not the app library.
library ecluse-manifest
  import:          shared
  hs-source-dirs:  manifest
  exposed-modules: Ecluse.Manifest
  build-depends:
    , ecluse:ecluse-core
    , aeson                      ^>=2.2
    , aeson-pretty               ^>=0.8
    , autodocodec                ^>=0.5
    , autodocodec-openapi3       ^>=0.3
    , http-media                 ^>=0.8
    , http-types                 ^>=0.12
    , insert-ordered-containers  ^>=0.2
    , openapi3                   ^>=3.2
    , text                       ^>=2.1

-- The capability-manifest generator: a build-time component that assembles the
-- OpenAPI document (Ecluse.Manifest) from the fixed canonical source and writes
-- the committed openapi.json. It depends on the ecluse-manifest sublibrary, NOT the
-- app library, so the OpenAPI dependency tree never reaches the running proxy. Run
-- with `cabal run openapi-gen`.
executable openapi-gen
  import:         shared
  main-is:        Main.hs
  hs-source-dirs: gen
  build-depends:
    , directory          ^>=1.3
    , ecluse:ecluse-manifest
    , filepath           ^>=1.5

