    , tasty-bench      ^>=0.4
    , tasty-bench-fit  ^>=0.1
    , tasty-hunit      ^>=0.10
    , text             ^>=2.1
    , time             ^>=1.12

-- Load benchmarks harness (S38): throughput & latency under concurrent load against the
-- real composed proxy. A separate EXECUTABLE (not a tasty-bench component): it boots
-- Ecluse.Server.application on warp over in-process stub upstreams and the in-memory
-- queue/credential doubles, drives the HTTP scenarios with `oha` (a subprocess, via
-- typed-process) and the worker scenario in-process, and captures RTS stats (peak
-- residency, GC pauses, allocations/request) — so it needs the threaded RTS (-threaded,
-- real warp + concurrency), -N (every core), and -T baked in (GHC.Stats). It links the
-- `ecluse` app library for the composed Application; kept out of the library closure.
-- INFORM-ONLY and not part of the gate. See docs/architecture/performance.md.
executable bench-load
  import:          shared
  main-is:         Main.hs
  hs-source-dirs:  bench/load

  -- The load harness drives in-process plain-http stub registries, so it needs the
  -- flag-gated loopback egress former (Ecluse.Core.Security.Egress.DevHttp). A
  -- release-posture build (the flag off -- the Nix docs/Haddock check included) has
  -- no such module by design, so this dev-only tool is simply not buildable there.
  if !flag(dev-http-egress)
    buildable: False
  -- Mirrors the shipped server's RTS tuning (-A64m -n4m; see `executable ecluse`)
  -- so the load benchmarks measure the runtime posture the proxy actually ships
  -- with; -T additionally exposes the RTS stats the harness reports.
  ghc-options:     -threaded -rtsopts "-with-rtsopts=-T -N -A64m -n4m"
  other-modules:
    Ecluse.BenchLoad.Error
    Ecluse.BenchLoad.Harness
    Ecluse.BenchLoad.Npm
    Ecluse.BenchLoad.Oha

  build-depends:
    , ecluse
    , ecluse:ecluse-bench-load
    , ecluse:ecluse-core
    , ecluse:ecluse-runtime
    , ecluse:ecluse-test-support
    , aeson            ^>=2.2
    , bytestring       ^>=0.12
    , containers       ^>=0.7
    , crypton          ^>=1.0
    , http-client      ^>=0.7
    , http-client-tls  ^>=0.3.6
    , http-types       ^>=0.12
    , iproute          ^>=1.7
    , katip            ^>=0.8.8
    , memory           ^>=0.18
    , text             ^>=2.1
    , time             ^>=1.12
    , typed-process    ^>=0.2.13
    , unliftio         ^>=0.2.25
    , wai              ^>=3.2
    , warp             ^>=3.4

-- Load benchmarks normalisation core: the PURE attribution and saturation maths the load
-- harness's two analysis views are built from (service-time upstream-vs-overhead split,
-- and the load-saturation queuing-delay flag). An INTERNAL sublibrary (the
-- ecluse-acceptance pattern) so the gating unit suite tests the maths deterministically,
-- while the live RTT probe + two-pass orchestration stay in the bench-load executable.
-- Carries no socket or load-generator dependency. See docs/architecture/performance.md.
library ecluse-bench-load
  import:          shared
  hs-source-dirs:  bench/load/src
  exposed-modules: Ecluse.BenchLoad.Normalise
  build-depends:   text ^>=2.1

-- Work-per-request bench report core: the PURE CSV-to-Markdown rendering behind the
-- bench run summary (parse the tasty-bench CSV, group by tasty path, render the
-- structured report). An INTERNAL sublibrary (the ecluse-bench-load pattern) so the
-- gating unit suite exercises the parse and rendering deterministically. No HTTP and
-- no egress former, so unlike bench-load it needs no dev-http-egress gating; kept
-- out of the shipped library closure.
library ecluse-bench-report
  import:          shared
  hs-source-dirs:  bench/report/src
  exposed-modules: Ecluse.BenchReport
