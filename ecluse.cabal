    , warp              ^>=3.4

-- Integration tests: exercise the real request path against in-process servers
-- (and, where they land, AWS-backed code against a ministack container via
-- testcontainers). Hermetic and gating; the AWS cases require a Docker daemon.
test-suite ecluse-integration
  import:             shared
  -- hspec-discover generates a Main without an export list. -threaded is required by
  -- the OpenTelemetry batch span processor the tracing integration test drives
  -- through the live SDK (it aborts under the non-threaded RTS).
  ghc-options:        -Wno-missing-export-lists -threaded
  type:               exitcode-stdio-1.0
  main-is:            Spec.hs
  hs-source-dirs:     test/integration
  other-modules:
    Ecluse.AwsEndToEndSpec
    Ecluse.Integration.Ministack
    Ecluse.MirrorQueueSpec
    Ecluse.Security.EgressOriginSpec
    Ecluse.Server.GracefulShutdownSpec
    Ecluse.Server.TarballHostSpec
    Ecluse.TelemetryMetricsSpec
    Ecluse.TelemetryTracingSpec
    Ecluse.Test.SupportLinkageSpec
    Ecluse.WorkerSpec

  build-tool-depends: hspec-discover:hspec-discover ^>=2.11
  build-depends:
    , aeson            ^>=2.2
    , amazonka         ^>=2.0
    , amazonka-sqs     ^>=2.0
