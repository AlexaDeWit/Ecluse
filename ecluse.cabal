-- Core unit tests: cover every Ecluse.Core.* module. Pure, fast, deterministic. Gating.
-- MUST NOT list the `ecluse` app library in build-depends: its absence is the partition
-- enforcement — an app spec accidentally placed here fails to compile.
test-suite ecluse-core-unit
  import:             shared
  -- hspec-discover generates a Main without an export list. -threaded is required
  -- by the admission wait (GHC.Conc.registerDelay aborts under the non-threaded
  -- RTS); the served process always runs threaded, so the suite matches it.
  ghc-options:        -Wno-missing-export-lists -threaded
  type:               exitcode-stdio-1.0
